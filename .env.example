# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Dev / cost control ---
# When true, all Claude calls are served by deterministic mock responses.
# Zero API spend. Used for tests, demos, and offline development.
DEV_MODE=true

# --- Database ---
DATABASE_PATH=./data/kt_assist.db
DATABASE_ECHO=false

# --- Caching (cost controls) ---
KAI_CACHE_DIR=./data/cache/kai
SCENARIO_CACHE_DIR=./data/cache/scenarios
CACHE_ENABLED=true

# --- Graph storage ---
GRAPH_STORAGE_DIR=./data/graphs

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
